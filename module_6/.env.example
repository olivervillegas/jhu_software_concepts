# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=pili
POSTGRES_DB=gradcafe

# Used by web + worker (compose will resolve "db" hostname)
DATABASE_URL=postgresql://postgres:password@db:5432/gradcafe

# RabbitMQ (compose will resolve "rabbitmq" hostname)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Web (optional)
FLASK_DEBUG=0
FLASK_SECRET=dev-secret-change-me