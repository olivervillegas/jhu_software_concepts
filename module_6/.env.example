# Postgres
POSTGRES_USER=gradcafe
POSTGRES_PASSWORD=gradcafe
POSTGRES_DB=gradcafe

# Used by web + worker (compose will resolve "db" hostname)
DATABASE_URL=postgresql://gradcafe:gradcafe@db:5433/gradcafe

# RabbitMQ (compose will resolve "rabbitmq" hostname)
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Web (optional)
FLASK_DEBUG=0
FLASK_SECRET=dev-secret-change-me
